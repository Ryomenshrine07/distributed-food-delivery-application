# Backend environment variables — set these in your shell or IDE run configuration
# before starting the services. Spring reads them via ${VAR} in application.properties.
# (This .example file is committed; do not put real secrets here.)

# Shared JWT signing secret — MUST be identical for api-gateway and auth services.
# Use a long random string (>= 32 characters). Do NOT reuse the old leaked value.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION=86400000

# Cloudinary credentials (restaurant-service image uploads) — from your Cloudinary dashboard.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Note: each service's Postgres password is a literal placeholder (e.g. "your_password")
# in its application.properties. Edit those directly for local development.
